# ========================================
# AI Simple Trader - Production Environment
# Railway Deployment Template
# ========================================
# 
# This file contains all environment variables needed for Railway deployment.
# Copy these to Railway Dashboard → Your Project → Variables
#
# ⚠️ NEVER commit actual secrets to git!
# ⚠️ Replace all placeholder values with real ones
# ========================================

# ========================================
# REQUIRED: Supabase Configuration
# ========================================
# Get these from: https://supabase.com/dashboard/project/whdljtbtqisoszbrzdwq/settings/api

# Supabase project URL (REQUIRED)
SUPABASE_URL=https://whdljtbtqisoszbrzdwq.supabase.co

# Supabase service role key (REQUIRED - KEEP SECRET!)
# ⚠️ NEVER expose this on frontend! Backend use only.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Edge function URL for push updates (REQUIRED)
SUPABASE_PUSH_UPDATE_URL=https://whdljtbtqisoszbrzdwq.supabase.co/functions/v1/push-update

# Webhook secret for edge function authentication (REQUIRED)
# Generate a random string: openssl rand -hex 32
SUPABASE_WEBHOOK_SECRET=your_webhook_secret_here

# Frontend Supabase config (for Railway environment variable reuse)
VITE_SUPABASE_URL=https://whdljtbtqisoszbrzdwq.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_publishable_key_here
VITE_SUPABASE_PROJECT_ID=whdljtbtqisoszbrzdwq

# ========================================
# REQUIRED: Trading Configuration
# ========================================

# Trading mode: paper (fake), dry_run (no orders), or live (real money)
# ⚠️ Start with 'paper' for safety!
TRADING_MODE=paper

# Maximum USD per order (safety limit)
MAX_NOTIONAL_PER_ORDER_USD=1.00

# Maximum orders per day (safety limit)
MAX_ORDERS_PER_DAY=20

# ========================================
# REQUIRED: Bot Configuration
# ========================================

# How often to check for new users to start bots (seconds)
BOT_POLL_INTERVAL_SECONDS=10

# How often each bot checks market and trades (seconds)
BOT_TICK_INTERVAL_SECONDS=30

# ========================================
# REQUIRED: CORS Configuration
# ========================================

# Allowed origins for API requests
# Development: Use '*' for any origin
# Production: Use your frontend domain like 'https://yourdomain.com'
BOT_CORS_ORIGINS=*

# ========================================
# REQUIRED: Database Configuration
# ========================================

# SQLite database path for local token storage
# Railway provides /data volume for persistence
BOT_SQLITE_PATH=/data/bot_data.sqlite

# ========================================
# OPTIONAL: Alpaca (Stock Trading)
# ========================================
# Can be set here OR via Settings UI in the app
# Get keys from: https://alpaca.markets

# Alpaca API key (optional if using Settings UI)
ALPACA_API_KEY=your_alpaca_api_key_here

# Alpaca secret key (optional if using Settings UI)
ALPACA_SECRET=your_alpaca_secret_here

# Use paper trading account (true) or live (false)
# ⚠️ Always start with true!
ALPACA_PAPER=true

# Stock symbols to trade (comma-separated)
ALPACA_SYMBOLS=AAPL,SPY

# ========================================
# OPTIONAL: Kraken (Crypto Trading)
# ========================================
# Can be set here OR via Settings UI in the app
# Get keys from: https://kraken.com/u/security/api

# Kraken API key (optional if using Settings UI)
KRAKEN_KEY=your_kraken_api_key_here

# Kraken secret key (optional if using Settings UI)
KRAKEN_SECRET=your_kraken_secret_here

# Crypto pairs to trade (comma-separated)
KRAKEN_PAIRS=XBTUSD,ETHUSD

# Enable live trading (false = read-only mode)
# ⚠️ Keep false until fully tested!
KRAKEN_ENABLE_TRADING=false

# Enable withdrawals (false = disabled)
# ⚠️ Keep false until fully tested!
KRAKEN_ENABLE_WITHDRAWALS=false

# Withdrawal configuration (only if withdrawals enabled)
# KRAKEN_WITHDRAW_ASSET=ZUSD
# KRAKEN_WITHDRAW_KEY_USD=your_kraken_withdrawal_key_name

# ========================================
# OPTIONAL: Plaid (Bank Integration)
# ========================================
# Can be set here OR via Settings UI in the app
# Get keys from: https://plaid.com/dashboard

# Plaid client ID (optional if using Settings UI)
PLAID_CLIENT_ID=your_plaid_client_id_here

# Plaid secret (optional if using Settings UI)
PLAID_SECRET=your_plaid_secret_here

# Plaid environment: sandbox, development, or production
# ⚠️ Start with sandbox!
PLAID_ENV=sandbox

# Plaid products to enable (comma-separated)
PLAID_PRODUCTS=auth,transactions

# Redirect URI for Plaid Link (optional)
# PLAID_REDIRECT_URI=https://yourdomain.com/plaid-callback

# Enable Plaid Transfer API (requires Plaid approval)
# ⚠️ Keep false unless approved by Plaid!
PLAID_ENABLE_TRANSFERS=false

# Enable Plaid Processor API (for partner integrations)
PLAID_ENABLE_PROCESSOR=true

# Plaid Transfer configuration (only if transfers enabled)
# PLAID_TRANSFER_AUTHORIZATION_ACCOUNT_ID=your_auth_account_id
# PLAID_TRANSFER_FUNDING_ACCOUNT_ID=your_funding_account_id

# ========================================
# OPTIONAL: OpenAI (AI Council)
# ========================================
# Can be set here OR via Settings UI in the app
# Get key from: https://platform.openai.com/api-keys

# OpenAI API key (optional if using Settings UI)
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI model to use for AI council
OPENAI_MODEL=gpt-4o-mini

# ========================================
# RAILWAY-SPECIFIC
# ========================================
# Railway sets these automatically, but you can override

# Port for the application (Railway sets this automatically)
# PORT=8000

# Railway deployment environment
# RAILWAY_ENVIRONMENT=production

# ========================================
# DEPLOYMENT CHECKLIST
# ========================================
#
# Before deploying to Railway:
# 
# 1. Required Variables (must set):
#    [ ] SUPABASE_URL
#    [ ] SUPABASE_SERVICE_ROLE_KEY
#    [ ] SUPABASE_PUSH_UPDATE_URL
#    [ ] SUPABASE_WEBHOOK_SECRET
#    [ ] VITE_SUPABASE_PUBLISHABLE_KEY
#    [ ] TRADING_MODE (start with 'paper')
#
# 2. Optional Variables (recommended):
#    [ ] ALPACA_API_KEY + ALPACA_SECRET (or set via Settings UI)
#    [ ] KRAKEN_KEY + KRAKEN_SECRET (or set via Settings UI)
#    [ ] OPENAI_API_KEY (or set via Settings UI)
#    [ ] BOT_CORS_ORIGINS (set to your domain)
#
# 3. Security Checks:
#    [ ] Service role key is secret (not in git)
#    [ ] TRADING_MODE is 'paper' for initial deployment
#    [ ] KRAKEN_ENABLE_TRADING is false
#    [ ] KRAKEN_ENABLE_WITHDRAWALS is false
#    [ ] PLAID_ENABLE_TRANSFERS is false
#    [ ] CORS is configured properly
#
# 4. Supabase Setup:
#    [ ] Database migrations applied (npx supabase db push)
#    [ ] Edge functions deployed (npx supabase functions deploy <name>)
#    [ ] Edge function secrets configured
#    [ ] RLS policies enabled
#
# 5. Testing:
#    [ ] /health endpoint returns ok: true
#    [ ] /config/status shows services configured
#    [ ] Can create user account
#    [ ] Can deposit funds
#    [ ] Can enable trading bot
#    [ ] Logs show no errors
#
# ========================================
# VARIABLE PRIORITY
# ========================================
#
# When a variable can be set in multiple places:
# 1. Railway Environment Variables (loaded at startup)
# 2. Settings UI / Database (dynamic, no restart needed)
# 3. User-specific keys in Supabase (per-user API keys)
#
# Recommendation:
# - Backend config (Supabase): Railway only
# - Trading keys (Alpaca/Kraken): Settings UI for multi-user
# - OpenAI: Settings UI for per-user control
#
# ========================================
# SECURITY BEST PRACTICES
# ========================================
#
# 1. Never commit secrets to git
# 2. Use Railway's environment variables for all secrets
# 3. Rotate keys regularly
# 4. Start with paper/sandbox mode
# 5. Enable 2FA on all exchange accounts
# 6. Set withdrawal whitelists on exchanges
# 7. Monitor API usage and costs
# 8. Use HTTPS only
# 9. Configure CORS to specific domains in production
# 10. Keep service role key absolutely secret
#
# ========================================
# MONITORING & LOGS
# ========================================
#
# Railway Logs: https://railway.app/dashboard
# - View real-time backend logs
# - Monitor errors and warnings
# - Check deployment status
#
# Supabase Logs: https://supabase.com/dashboard/project/whdljtbtqisoszbrzdwq/logs
# - Database queries
# - Edge function calls
# - Authentication events
#
# OpenAI Usage: https://platform.openai.com/usage
# - API call counts
# - Token usage
# - Cost tracking
#
# Exchange APIs:
# - Alpaca: Check paper vs live mode carefully
# - Kraken: Monitor order history
# - Set up alerts for unusual activity
#
# ========================================
# COST ESTIMATES (approximate)
# ========================================
#
# Railway: $5-10/month (Hobby plan)
# Supabase: Free tier (up to 500MB database, 2GB bandwidth)
# OpenAI: ~$0.01-0.05 per trading decision (gpt-4o-mini)
# Alpaca: Free for paper trading
# Kraken: Free API access, trading fees apply
# Plaid: Free for development, paid for production
#
# Total estimated monthly cost: $5-15 (excluding trading fees)
#
# ========================================

