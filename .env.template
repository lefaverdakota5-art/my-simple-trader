# ── Supabase ──────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_PUSH_UPDATE_URL=https://your-project-ref.supabase.co/functions/v1/push-update
SUPABASE_WEBHOOK_SECRET=your-webhook-secret-here

# ── Trading API Keys ──────────────────────────────────────────────
# Kraken (crypto)
KRAKEN_API_KEY=your-kraken-api-key
KRAKEN_SECRET=your-kraken-api-secret

# Alpaca (stocks — paper trading by default)
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET=your-alpaca-secret-key

# ── OpenAI (optional — enables 4-agent AI council) ────────────────
OPENAI_API_KEY=your-openai-api-key-here

# ── Trading Mode ─────────────────────────────────────────────────
# Options: paper | dry_run | live
TRADING_MODE=paper

# Risk controls
MAX_NOTIONAL_PER_ORDER_USD=1.00
MAX_ORDERS_PER_DAY=20

# ── Bot Timing ───────────────────────────────────────────────────
BOT_POLL_INTERVAL_SECONDS=10
BOT_TICK_INTERVAL_SECONDS=30

# ── Local Storage ────────────────────────────────────────────────
BOT_SQLITE_PATH=bot_data.sqlite

# ── CORS ─────────────────────────────────────────────────────────
BOT_CORS_ORIGINS=*

# ── Logging ──────────────────────────────────────────────────────
DEBUG=false
LOG_FILE=false

# ── Vite (frontend) ──────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
