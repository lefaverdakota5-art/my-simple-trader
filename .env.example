# Trading Configuration
TRADING_MODE=paper  # paper|dry_run|live
MAX_NOTIONAL_PER_ORDER_USD=1.00
MAX_ORDERS_PER_DAY=20
BOT_POLL_INTERVAL_SECONDS=10
BOT_TICK_INTERVAL_SECONDS=30

# Alpaca (Stock Trading) - Optional, can be set via Settings UI
# ALPACA_API_KEY=your_alpaca_key_here
# ALPACA_SECRET=your_alpaca_secret_here
# ALPACA_PAPER=true
# ALPACA_SYMBOLS=AAPL,SPY

# Kraken (Crypto Trading) - Optional, can be set via Settings UI
# KRAKEN_KEY=your_kraken_key_here
# KRAKEN_SECRET=your_kraken_secret_here
# KRAKEN_PAIRS=XBTUSD,ETHUSD
KRAKEN_ENABLE_TRADING=false
KRAKEN_ENABLE_WITHDRAWALS=false

# Plaid (Bank Integration) - Optional, can be set via Settings UI
# PLAID_CLIENT_ID=your_plaid_client_id_here
# PLAID_SECRET=your_plaid_secret_here
# PLAID_ENV=sandbox  # sandbox|development|production
# PLAID_PRODUCTS=auth,transactions
PLAID_ENABLE_TRANSFERS=false
PLAID_ENABLE_PROCESSOR=true

# OpenAI (AI Council) - Optional, can be set via Settings UI
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini

# CORS (for backend)
BOT_CORS_ORIGINS=*

# Local SQLite Database
BOT_SQLITE_PATH=bot_data.sqlite
