# Supabase Configuration (Frontend)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
VITE_SUPABASE_PROJECT_ID=your_supabase_project_id_here

# Backend Configuration (Python FastAPI)
# Supabase (Backend)
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_PUSH_UPDATE_URL=your_supabase_edge_function_url_here
SUPABASE_WEBHOOK_SECRET=your_webhook_secret_here

# Trading Configuration
TRADING_MODE=paper  # Options: paper, dry_run, live
MAX_NOTIONAL_PER_ORDER_USD=1.00
MAX_ORDERS_PER_DAY=20

# Bot Configuration
BOT_POLL_INTERVAL_SECONDS=10
BOT_TICK_INTERVAL_SECONDS=30
BOT_SQLITE_PATH=bot_data.sqlite
BOT_CORS_ORIGINS=*

# Alpaca (Stock Trading)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET=your_alpaca_secret_here
ALPACA_PAPER=true  # Set to false for live trading
ALPACA_SYMBOLS=AAPL,SPY,TSLA

# Kraken (Crypto Trading)
KRAKEN_KEY=your_kraken_api_key_here
KRAKEN_SECRET=your_kraken_secret_here
KRAKEN_PAIRS=XBTUSD,ETHUSD
KRAKEN_ENABLE_TRADING=false  # Set to true to enable live trading
KRAKEN_ENABLE_WITHDRAWALS=false  # Set to true to enable withdrawals
KRAKEN_WITHDRAW_ASSET=ZUSD
KRAKEN_WITHDRAW_KEY_USD=your_kraken_withdrawal_key_here

# Plaid (Bank Integration)
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_secret_here
PLAID_ENV=sandbox  # Options: sandbox, development, production
PLAID_PRODUCTS=auth,transactions
PLAID_REDIRECT_URI=your_redirect_uri_here
PLAID_ENABLE_TRANSFERS=false
PLAID_ENABLE_PROCESSOR=true
PLAID_TRANSFER_AUTHORIZATION_ACCOUNT_ID=your_plaid_transfer_auth_account_id
PLAID_TRANSFER_FUNDING_ACCOUNT_ID=your_plaid_funding_account_id

# OpenAI (AI Council)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini  # Options: gpt-4, gpt-4o, gpt-4o-mini, gpt-3.5-turbo
OPENAI_ENABLED=false  # Set to true to enable AI council
SWARM_AI_COUNT=5  # Number of AI agents in the council

# Port Configuration
PORT=8000
